^/remote/fgt_lang
^/remote/login
^/\+cscoe\+/
^/bin/sh$
^/api/v2/cmdb/system/admin/admin
^/HNAP1
^/SDK/webLanguage
^/boaform/
^/cgi-bin/
^/actuator
^/geoserver
^/solr/
^/manager/(html|text)
^/login\.action$
^/struts
^/v2/_catalog$
^/_all_dbs$
^/dns-query
^/resolve\?
^/scripts/WPnBr\.dll$
(^|/)Telerik\.Web\.UI\.WebResource\.axd
(^|/)GponForm/
^/\+CSCOL\+/
(^|/)developmentserver/metadatauploader
^/config/getuser
^/dana-na/
^/dana-cached/
^/mgmt/tm/util/bash
^/api/sonicos/
(^|/)mifs/
^/CFIDE/
^/sitecore/
^/RDWeb/
^/evox/about
^/parastable/
(^|/)etc/passwd

# ---- credential / config / infra-API leaks --------------------------------
# Config/IaC/secret files are never served at this edge (baseline serves only
# /, /app.*, static assets), so blanket extension rules for config-only formats
# (.yml/.yaml/.properties/.tfstate/.tfvars) have no false-positive surface here
# -- validated by the work-stream B detect FP gate. Distinctive .json/dotfile
# secret stores are enumerated instead (a blanket .json rule would hit the
# /app.json baseline). 2026-06 gap-loop, extended.
(^|/)aws/credentials
^/credentials$
^/.*\.env$
^/.*\.ya?ml$
^/.*\.properties$
^/.*\.tfstate
^/.*\.tfvars$
(^|/)appsettings(\.[A-Za-z]+)?\.json$
(^|/)credentials\.json$
(^|/)client_secrets\.json$
(^|/)secrets\.json$
(^|/)auth\.json$
(^|/)composer\.(json|lock)$
(^|/)sftp-config\.json$
(^|/)settings\.json$
(^|/)local\.settings\.json$
(^|/)\.runtimeconfig\.json$
(^|/)env\.(json|txt)$
(^|/)connectionstrings\.config$
^/Web\.(Debug|Release)\.config$
^/web\.config[~.]
(^|/)settings\.py$
(^|/)global\.asax$
(^|/)\.npmrc$
(^|/)\.netrc$
(^|/)\.htpasswd$
(^|/)\.dockerenv$
(^|/)\.kube/
(^|/)\.composer/
(^|/)\.docker/config\.json$
(^|/)config/credentials
(^|/)config/master\.key$
(^|/)storage/logs/
^/error\.log$
^/env$
(^|/)containers/json
^/server-status
^/server-info$
^/nginx_status$
^/druid/

# ---- generic admin / installer probes -------------------------------------
^/administrator
^/ReportServer
^/Temporary_Listen_Addresses

