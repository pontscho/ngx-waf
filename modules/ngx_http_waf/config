# ngx_http_waf_module - build descriptor
#
# One dynamic .so registering TWO modules: ngx_http_waf_module (HTTP) and
# ngx_stream_waf_module (STREAM, the L4 reputation head). auto/module names
# the .so after the first entry in ngx_module_name and compiles every listed
# module into it; each module declares its own type at runtime.
#
# No external libraries: PCRE2 comes from nginx's own ngx_regex (already
# linked), and the geo reader is the embedded nanolibloc adaptation (libc
# only). ngx_module_libs stays empty. Requires nginx built --with-stream.

ngx_addon_name=ngx_http_waf_module

waf_deps="$ngx_addon_dir/src/ngx_http_waf.h \
         $ngx_addon_dir/src/waf_match.h \
         $ngx_addon_dir/src/waf_spoof.h \
         $ngx_addon_dir/src/waf_geo.h \
         $ngx_addon_dir/src/waf_rep.h \
         $ngx_addon_dir/src/waf_reputation.h \
         $ngx_addon_dir/src/waf_authhttp.h \
         $ngx_addon_dir/src/waf_status.h \
         $ngx_addon_dir/src/waf_ja4.h"

waf_srcs="$ngx_addon_dir/src/ngx_http_waf_module.c \
         $ngx_addon_dir/src/waf_match.c \
         $ngx_addon_dir/src/waf_spoof.c \
         $ngx_addon_dir/src/waf_geo.c \
         $ngx_addon_dir/src/waf_reputation.c \
         $ngx_addon_dir/src/waf_authhttp.c \
         $ngx_addon_dir/src/waf_stream.c \
         $ngx_addon_dir/src/waf_status.c \
         $ngx_addon_dir/src/waf_ja4.c"

if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name="ngx_http_waf_module ngx_stream_waf_module"
    ngx_module_incs="$ngx_addon_dir/src"
    ngx_module_deps="$waf_deps"
    ngx_module_srcs="$waf_srcs"
    ngx_module_libs=
    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_waf_module"
    STREAM_MODULES="$STREAM_MODULES ngx_stream_waf_module"
    NGX_ADDON_DEPS="$NGX_ADDON_DEPS $waf_deps"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $waf_srcs"
    CORE_INCS="$CORE_INCS $ngx_addon_dir/src"
fi
