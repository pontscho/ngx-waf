# CMake super-build outputs
/build/

# build-time downloads / extracted trees (all fetched by CMake now)
/openssl-*.tar.gz
/nginx-*.tar.gz
/zlib-ng-*.tar.gz
/openssl-*/
/nginx-*/
/zlib-ng-*/

# geo database (downloaded artifact, not source)
geodb/*.db
geodb/*.db.*

# sandbox runtime + build-installed nginx (prefix = sandbox/)
sandbox/sbin/
sandbox/modules/
sandbox/conf/
sandbox/logs/
sandbox/*_temp/

# editor / tooling state
.claude/

# webfetch / curl cache (work-stream B external pulls, local-only)
.cache/

# raw honeypot access logs (~450MB, partner-managed, never committed)
ngxlogs/

# honeypot corpus: the input FEEDs (replay-*-vectors.jsonl + summary) and the
# external/synthetic fixtures ARE committed -- partner decision; they are
# IP-free corpus derivatives and the harness reproduces everything else from
# them. Only the per-run RESULTS and generated REPORTS stay ignored: they are
# regenerated by run-replay-tests.sh from the committed feeds + fixtures.
/modules/ngx_http_heavybag/tests/corpus/replay-*-results.jsonl
/modules/ngx_http_heavybag/tests/corpus/replay-fp-report.txt
/modules/ngx_http_heavybag/tests/corpus/replay-coverage-report.txt
/modules/ngx_http_heavybag/tests/corpus/replay-uncovered.jsonl

# work-stream D (offline ASN/geo tuning): the per-IP volume FEED is IP-bearing
# and the report is its derivative. Both are regenerated by run-honeypot-d.sh
# from the (gitignored) raw access log + the geo DB; neither is ever committed
# (Decision #75: IP-bearing per-run results stay out of git).
/modules/ngx_http_heavybag/tests/corpus/replay-ip-volume.jsonl
/modules/ngx_http_heavybag/tests/corpus/honeypot-d-report.md

# work-stream C regression net: the FROZEN fixtures (regression-vectors.jsonl +
# regression-headers.jsonl) ARE committed -- they carry the expected verdicts
# the enforce harness asserts. Only the freeze/harness per-run scratch dir
# (detect/enforce probe outputs, covered-subset feeds, compare.pl) is ignored.
/modules/ngx_http_heavybag/tests/corpus/.freeze-tmp/

# Python bytecode cache (created when the offline ja4.list regen script under
# modules/ngx_http_heavybag/tools/ is imported as a module for diagnostics; never
# source -- the .py itself is committed, the cache is regenerated on demand).
__pycache__/
*.pyc
